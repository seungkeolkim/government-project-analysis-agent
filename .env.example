# 사업공고 스크래퍼 환경변수 샘플
# 이 파일을 .env 로 복사한 뒤 호스트마다 다른 값을 직접 채워 사용한다.
# 실제 .env 파일은 git 에 커밋하지 않는다 (.gitignore 대상).
#
# 흐름은 README.USER.md 의 "시작하기 → 초기 설치 (요약)" 와 동일한 순서다.
# 위에서부터 차례로 채우면 된다.
#
# 소스별 URL·페이지 한도 등 상세 파라미터는 sources.yaml 에서 관리한다.

# ──────────────────────────────────────────────────────────────
# 1. 호스트 통합 변수 (필수)
#    컨테이너가 호스트와 같은 유저·그룹·경로·시각으로 동작하도록 맞춘다.
# ──────────────────────────────────────────────────────────────

# 컨테이너를 호스트 유저 UID:GID 로 실행해, 컨테이너가 만드는 모든 파일
# (SQLite DB, 다운로드, 로그 등) 의 owner 를 호스트 유저로 맞춘다.
# docker-compose.yml 의 `user: "${HOST_UID}:${HOST_GID}"` 가 이 값을 참조한다.
#
# 호스트 쉘에서 아래 명령으로 값을 확인한다:
#   id -u   # → HOST_UID
#   id -g   # → HOST_GID
#
# 빠지면: user 가 빈 문자열로 해석되어 root(uid=0) 로 실행되고,
# 생성 파일이 root:root 소유가 되어 호스트에서 sudo 없이는 수정·삭제할 수 없다.
# 변경 후에는 이미지 재빌드(`./compose.sh dev build`) 가 필수다.
HOST_UID=
HOST_GID=

# app 컨테이너가 호스트 /var/run/docker.sock 으로 docker CLI 를 호출하려면,
# 컨테이너 내부 유저가 호스트 docker 그룹의 gid 를 보조 그룹으로 가져야 한다.
# docker-compose.yml 의 `group_add` 가 이 값을 참조한다.
#
# 호스트 쉘에서 아래 명령으로 값을 확인한다 (호스트마다 다르다):
#   getent group docker | cut -d: -f3
#
# 빠지면: 웹 UI 의 "지금 시작" 클릭 시 컨테이너 내부에서
# `docker ps` 가 "Permission denied on docker.sock" 으로 실패한다.
#
# 보안 경고: docker.sock 마운트는 사실상 호스트 root 권한 부여와 동등하다.
# FastAPI 를 외부 네트워크에 노출하지 말 것 (로컬 또는 내부 VPN 한정).
HOST_DOCKER_GID=

# 호스트에 존재하는 프로젝트 루트의 절대 경로.
# app 컨테이너의 웹/스케줄러가 `docker compose` 를 subprocess 로 호출할 때
# `--project-directory $HOST_PROJECT_DIR` 로 전달해, compose 파일 안의
# 상대 경로(./app, ./data 등)를 호스트 기준으로 해석하게 한다.
#
# 호스트 쉘에서 아래 명령으로 값을 확인한다:
#   pwd   # 이 프로젝트 루트에서
#
# 빠지면: runner 가 ComposeEnvironmentError 를 발생시키고
# 웹 UI 에 flash 로 노출되며, 해당 ScrapeRun 은 failed 로 마감된다.
HOST_PROJECT_DIR=

# app·scraper 컨테이너 내부 프로세스가 사용할 IANA 타임존 이름.
# loguru 로그 타임스탬프, `date` 출력 등 프레젠테이션 계층 시각만 바꾼다.
# DB 저장 컬럼은 여전히 UTC 로 저장된다 (KST 변환은 표시 경계에서만).
#
# 기본값 Asia/Seoul 은 docker-compose.yml 이 fallback 으로 제공하므로
# 한국에서 운영한다면 이 값을 비워 두어도 된다. 다른 지역에서 운영하거나
# 컨테이너 OS 시각만 UTC 등으로 두고 싶을 때만 명시한다.
# 예) HOST_TZ=UTC, HOST_TZ=Europe/Berlin
# HOST_TZ=Asia/Seoul

# ──────────────────────────────────────────────────────────────
# 2. Compose 식별 (대부분 기본값 그대로 둔다)
# ──────────────────────────────────────────────────────────────

# docker compose CLI 가 생성·관리하는 컨테이너의 prefix.
# 기본값 iris-agent 를 그대로 두면 컨테이너 이름이
# iris-agent-web / iris-agent-scraper 로 만들어진다.
# 운영 중 변경하면 기존 컨테이너와 대응 관계가 끊어지므로 권장하지 않는다.
# COMPOSE_PROJECT_NAME=iris-agent

# docker CLI 바이너리의 절대경로. 비표준 경로(예: /opt/docker-ce/bin/docker)
# 에 docker 를 설치한 환경의 비상 수단이며, 일반 환경에서는 비워 둔다.
# 비워 두면 PATH 와 /usr/bin/docker, /usr/local/bin/docker 를 자동 탐색한다.
# DOCKER_BINARY=

# ──────────────────────────────────────────────────────────────
# 3. DB 및 로컬 저장 경로 (대부분 기본값 그대로 둔다)
#    경로는 컨테이너 내부 기준이며, ./data/ 를 호스트에 바인드 마운트한다.
# ──────────────────────────────────────────────────────────────

# 메인 DB 접속 문자열. 기본은 로컬 SQLite.
# Postgres 등으로 옮길 때만 변경한다.
DB_URL=sqlite:///./data/db/app.sqlite3

# 게시판(건의사항·공지사항) 전용 DB 접속 문자열.
# 메인 DB(app.sqlite3) reset 으로 게시글이 사라지지 않도록 별도 파일에 저장한다.
# 일반 운영에서는 변경할 일이 없다.
# SUGGESTIONS_DB_URL=sqlite:///./data/db/boards.sqlite3

# 첨부파일 다운로드 루트 디렉터리 (상대경로면 프로젝트 루트 기준).
# DOWNLOAD_DIR=./data/downloads

# IP 접근 이력 로그파일(access_history_YYMMDD.log) 저장 디렉터리.
# 관리자 페이지 "이용 통계" 가 이 디렉터리의 jsonl 을 읽어 집계한다.
# ACCESS_LOG_DIR=./data/logs

# ──────────────────────────────────────────────────────────────
# 4. 스크래핑 동작 (전역 fallback)
#    소스별 동작은 sources.yaml 의 sources.<id> 가 우선한다.
# ──────────────────────────────────────────────────────────────

# 요청 사이 최소 지연 시간(초). 차단 방지 목적이라 너무 짧게 두지 않는다.
# sources.yaml 의 소스별 request_delay_sec 이 있으면 그쪽이 우선한다.
REQUEST_DELAY_SEC=1.5

# HTTP 요청에 사용할 User-Agent. 빈 문자열이면 각 스크래퍼 어댑터의 기본값을 쓴다.
# USER_AGENT=

# ──────────────────────────────────────────────────────────────
# 5. 소스별 인증 (로그인이 필요한 소스에만 설정)
#    환경변수 이름 규칙: {SOURCE_ID}_USERNAME / {SOURCE_ID}_PASSWORD
# ──────────────────────────────────────────────────────────────

# NTIS: 게스트 수집 가능. 설정하지 않아도 된다.
# NTIS_USERNAME=
# NTIS_PASSWORD=

# IRIS: 로그인 필요 여부 미확인. 인증이 필요해지면 주석을 풀고 채운다.
# IRIS_USERNAME=
# IRIS_PASSWORD=

# ──────────────────────────────────────────────────────────────
# 6. 로깅
# ──────────────────────────────────────────────────────────────

# 루트 로거 레벨. DEBUG / INFO / WARNING / ERROR 중 하나.
# 평소 운영은 INFO. 500 에러·인증 실패·수집 이상 추적에는 DEBUG 로 올린다.
# 변경 후 컨테이너 재기동 필요: `docker compose restart app`.
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# 7. 운영 한도 (대부분 기본값 그대로 둔다)
# ──────────────────────────────────────────────────────────────

# 목록의 "현재 필터 결과 전체 M건 선택" 일괄 읽음/안읽음 처리의 1회 상한.
# 이 값을 넘으면 422 + 선택 유지로 거부된다.
# MAX_BULK_MARK=5000

# IP 접근 이력 방문 집계 세션의 비활성 기준(분).
# 같은 IP 에서 마지막 요청 후 이 시간 이상 무활동이면 새 방문으로 카운트한다.
# 60 으로 두면 "1시간 단위 방문 집계" 와 동치다.
# ACCESS_HISTORY_SESSION_GAP_MINUTES=30
