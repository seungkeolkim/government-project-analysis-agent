# 사업공고 스크래퍼 환경변수 샘플
# 이 파일을 .env 로 복사한 뒤 실제 값으로 수정하여 사용한다.
# 실제 .env 파일은 git에 커밋하지 않는다 (.gitignore 대상).
#
# 소스별 세부 설정(base_url, request_delay_sec 등)은 sources.yaml 에서 관리한다.
# 아래 REQUEST_DELAY_SEC 는 sources.yaml 에 값이 없을 때 쓰이는 전역 fallback 이다.

# ──────────────────────────────────────────────────────────────
# 스크래핑 공통 설정 및 네트워크 정책
# ──────────────────────────────────────────────────────────────

# 요청 사이 지연 시간(초). 차단 방지를 위해 너무 짧게 설정하지 않는다.
# sources.yaml 의 소스별 request_delay_sec 이 우선 적용된다.
REQUEST_DELAY_SEC=1.5

# ──────────────────────────────────────────────────────────────
# 저장소 경로 (컨테이너 내부 기준 경로)
# ──────────────────────────────────────────────────────────────

# 데이터베이스 접속 문자열. 기본은 로컬 SQLite.
DB_URL=sqlite:///./data/db/app.sqlite3

# ──────────────────────────────────────────────────────────────
# 소스별 인증 정보 (로그인이 필요한 소스에만 설정)
# 환경변수 이름 규칙: {SOURCE_ID}_USERNAME / {SOURCE_ID}_PASSWORD
# ──────────────────────────────────────────────────────────────

# NTIS: 로그인 불필요 (게스트 수집 가능). 설정하지 않아도 된다.
# NTIS_USERNAME=
# NTIS_PASSWORD=

# IRIS: 현재 로그인 필요 여부 미확인. 필요한 경우 아래 주석 해제 후 설정.
# IRIS_USERNAME=
# IRIS_PASSWORD=

# ──────────────────────────────────────────────────────────────
# 로깅
# ──────────────────────────────────────────────────────────────

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# 웹 수집 제어 (Phase 2 / 00025)
# ──────────────────────────────────────────────────────────────

# app 컨테이너가 호스트 /var/run/docker.sock 을 통해 docker CLI 호출을 수행하려면,
# 컨테이너 내부 유저(root)가 호스트 docker 그룹의 gid 를 보조 그룹으로 보유해야 한다.
# docker-compose.yml 의 `group_add` 설정이 이 값을 참조한다.
#
# 호스트에서 다음 명령으로 실제 gid 를 확인한 뒤 값으로 설정한다:
#   getent group docker | cut -d: -f3
#
# 값을 설정하지 않으면 docker-compose.yml 의 fallback (999) 이 적용되며,
# gid 가 실제 호스트 docker 그룹과 일치하지 않으면 app 컨테이너에서
# `docker ps` 호출이 "Permission denied on /var/run/docker.sock" 로 실패한다.
#
# **보안 경고**: docker.sock 마운트는 사실상 호스트 root 권한 부여와 동등하다
# (docs/scrape_control_design.md §15.1). FastAPI 를 외부 네트워크에 노출하지 않는다는
# 기존 전제가 이 구성으로 더 강하게 요구된다.
# HOST_DOCKER_GID=999

# 호스트에 존재하는 프로젝트 루트의 **절대** 경로.
# app 컨테이너의 웹/스케줄러가 `docker compose` 를 subprocess 로 호출할 때
# `--project-directory $HOST_PROJECT_DIR` 플래그로 전달해, compose 파일 안의
# 상대 경로(`./app`, `./data` 등)를 호스트 기준으로 해석하게 한다.
# 값이 비어 있으면 runner 가 ComposeEnvironmentError 를 발생시키고 ScrapeRun 은
# failed 로 마감된다 (docs/scrape_control_design.md §5.3, §9).
#
# 확인 방법(호스트 쉘에서):
#   pwd   # 이 프로젝트의 루트 경로를 복사
#
# 예) HOST_PROJECT_DIR=/home/azzibobjo/workspace/government-project-analysis-agent
# HOST_PROJECT_DIR=

# compose 프로젝트 이름. docker compose CLI 가 생성/관리할 컨테이너의 prefix 로
# 사용된다. 기본값 iris-agent 는 기존 CLI 경로의 프로젝트 이름과 맞춰 회귀를 피한다.
# 바꿀 경우 기존 컨테이너 이름(iris-agent-web / iris-agent-scraper) 과 대응 관계가
# 끊어지므로 운영 중에는 변경하지 않는 것을 권장한다.
# COMPOSE_PROJECT_NAME=iris-agent
