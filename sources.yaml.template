# ──────────────────────────────────────────────────────────────
# [TEMPLATE] 이 파일은 템플릿입니다.
#
# 초기 설정 방법:
#   cp -n sources.yaml.template sources.yaml
#   또는
#   sh ./bootstrap_sources.sh
#
# sources.yaml 은 .gitignore 대상이므로 브랜치 전환 시 로컬 수정이 유지됩니다.
# 이 파일(sources.yaml.template)은 커밋되어 있으며, 로컬 수정 시 덮어쓰지 마세요.
# ──────────────────────────────────────────────────────────────

# 공고 수집 설정
# 실행: docker compose --profile scrape run --rm scraper
# CLI 인자 없이 이 파일과 .env 로 모든 동작을 제어한다.

# ──────────────────────────────────────────────────────────────
# 1. 전역 수집 실행 설정 (scrape:)
#    이 블록의 값은 sources 의 소스별 설정보다 우선한다 (active_sources / log_level
#    제외). 비워 두면 소스별 설정 → 코드 default 순으로 fallback 한다.
# ──────────────────────────────────────────────────────────────
scrape:
  # 실행할 소스 ID 목록. 비어 있으면 아래 sources 중 enabled: true 인 소스 전체를 실행한다.
  # 특정 소스만 실행하려면 예: active_sources: [NTIS]
  active_sources: []

  # 소스당 최대 페이지 수.
  # null 이면 소스별 max_pages 설정 → 코드 default(10) 순으로 사용.
  max_pages: null

  # 소스당 최대 공고 수.
  # null 이면 소스별 max_announcements 설정 → 코드 default(200) 순으로 사용.
  max_announcements: null

  # true 면 상세 페이지 수집을 건너뛴다 (목록 적재만 수행).
  skip_detail: false

  # true 면 첨부파일 다운로드를 건너뛴다 (목록·상세 수집은 정상 진행).
  skip_attachments: false

  # true 면 DB 쓰기를 건너뛴다 (수집 동작만 검증할 때 사용).
  dry_run: false

  # 로그 레벨 오버라이드. null 이면 .env 의 LOG_LEVEL 사용.
  # log_level: DEBUG

# ──────────────────────────────────────────────────────────────
# 2. 소스별 크롤링 설정 (sources:)
#    enabled: true 인 소스만 크롤러 실행 시 활성화된다.
#    각 소스 id 는 app/sources/constants.py 의 SOURCE_TYPE_* 상수와 일치해야 한다.
#
#    인증이 필요한 소스는 yaml 에 비밀번호를 적지 않고 환경변수로 주입한다:
#      {SOURCE_ID}_USERNAME / {SOURCE_ID}_PASSWORD  (예: IRIS_USERNAME)
# ──────────────────────────────────────────────────────────────
sources:
  - id: IRIS
    enabled: true
    base_url: https://www.iris.go.kr/contents/retrieveBsnsAncmBtinSituListView.do
    request_delay_sec: 1.5
    statuses:
      - 접수예정
      - 접수중
      - 마감

  - id: NTIS
    enabled: true
    # 목록 POST 엔드포인트. 자세한 사이트 구조는 docs/ntis_site_exploration.md 참조.
    base_url: https://www.ntis.go.kr/rndgate/eg/un/ra/mng.do
    request_delay_sec: 2.0
    # NTIS 마감 공고가 74,000건+ 으로 매우 많아 기본값을 보수적으로 둔다.
    # 전체 수집이 필요하면 위 scrape.max_pages / scrape.max_announcements 또는
    # 이 값을 늘려 사용한다.
    max_pages: 5
    max_announcements: 100
    statuses:
      - 접수예정
      - 접수중
      - 마감
